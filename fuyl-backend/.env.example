# ─────────────────────────────────────────────
# Fuyl Backend — Environment Variables
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

NODE_ENV=development
PORT=4000
APP_NAME=Fuyl Backend
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# Absolute, publicly-reachable logo URL for transactional emails. Leave blank
# to use CLIENT_URL + /logo.webp. Set this in production to a hosted PNG/JPG —
# email clients can't load images from localhost and several (Outlook/Windows
# Mail) don't render WebP.
EMAIL_LOGO_URL=

# Comma-separated list of allowed CORS origins (storefront + admin dashboard).
# Falls back to CLIENT_URL + http://localhost:3001 (admin dev port) if unset.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Must match fuyl-frontend's REVALIDATE_SECRET — used to call its
# POST /api/revalidate after a product/post is created, updated, deleted,
# published, or unpublished, so the storefront's ISR cache reflects it
# immediately instead of waiting out that page's revalidate window.
REVALIDATE_SECRET=change-me-to-a-random-string

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fuyl

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_COOKIE_NAME=fuyl_refresh

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# Cloudinary / S3
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@fuyl.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Firebase (Push, via firebase-admin) — service account credentials, not
# the deprecated FCM legacy server key. Leave unset in dev: push
# notifications fall back to logging only (see pushProvider.ts).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# WhatsApp BSP
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Instagram (homepage feed) — long-lived User Access Token from "Instagram
# API with Instagram Login" (requires a Business/Creator account). Leave
# unset in dev: the homepage feed falls back to static placeholders.
# https://developers.facebook.com/docs/instagram-platform/instagram-api-with-instagram-login
INSTAGRAM_ACCESS_TOKEN=

# Default Rewards (Referral)
DEFAULT_REFERRER_REWARD=100
DEFAULT_REFEREE_REWARD=50
DEFAULT_REFERRAL_CODE_EXPIRY_DAYS=90
DEFAULT_WALLET_EXPIRY_DAYS=90

# Default Subscription Settings
DEFAULT_SUBSCRIPTION_REMINDER_DAYS=3
DEFAULT_DUNING_MAX_RETRIES=3
DEFAULT_DUNING_RETRY_INTERVAL_HOURS=24
